<?xml version="1.0" encoding="utf-8"?>
<!--
    Root: FrameLayout so the control panel floats OVER the GLSurfaceView.
    The GLSurfaceView fills the whole screen; the card panel sits at the bottom.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- ── OpenGL Surface ─────────────────────────────────────────────── -->
    <android.opengl.GLSurfaceView
        android:id="@+id/gl_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Tap hint (top-right) ───────────────────────────────────────── -->
    <TextView
        android:id="@+id/tap_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:padding="8dp"
        android:text="⚙ Controls"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:background="@drawable/bg_pill"
        android:clickable="true"
        android:focusable="true" />

    <!-- ── Control Panel (bottom) ────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/control_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_panel"
        android:visibility="visible">

        <!-- Speed row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐢"
                android:textSize="18sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/speed_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="20"
                android:progress="5"
                android:progressTint="#7B61FF"
                android:thumbTint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐇"
                android:textSize="18sp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/speed_label"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="Speed: 0.5"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:gravity="end"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_media_pause"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Pause / Play"
                android:scaleType="centerInside"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btn_reset"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Reset"
                android:scaleType="centerInside"
                android:padding="10dp" />

            <ImageButton
                android:id="@+id/btn_screenshot"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_camera"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Screenshot"
                android:scaleType="centerInside"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Hint text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Trage pentru a roti · Pinch pentru zoom · Double-tap pentru reset"
            android:textColor="#88FFFFFF"
            android:textSize="11sp"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>